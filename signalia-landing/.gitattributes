# Force LF line endings for all text files
* text=auto eol=lf

# Explicitly LF for source files
*.css    text eol=lf
*.tsx    text eol=lf
*.ts     text eol=lf
*.js     text eol=lf
*.json   text eol=lf
*.md     text eol=lf

# Binary files
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.woff   binary
*.woff2  binary
*.avif   binary
*.webp   binary
